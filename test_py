import os
import json
import numpy as np
import fitz  # type: ignore
import pdfplumber  # type: ignore
import chromadb
from chromadb.utils import embedding_functions
from chromadb.api.types import EmbeddingFunction
from langchain_text_splitters import RecursiveCharacterTextSplitter
from typing import Dict, Any, List, Optional, cast
from typing import cast

class DVPCompletePipeline:
   def __init__(self, collection_name: str = "dvp1_brakes_collection"):
       # Initialize Local ChromaDB client
       self.chroma_client = chromadb.PersistentClient(path="./chroma_db_storage")
       
       # Explicit type annotation satisfies Pylance completely
       self.embed_fn = cast(EmbeddingFunction, embedding_functions.DefaultEmbeddingFunction())
       
       # Setup or fetch the vector collection safely
       self.collection = self.chroma_client.get_or_create_collection(
           name=collection_name, 
           embedding_function=self.embed_fn
       )
       
       # Text splitter for regular paragraphs
       self.text_splitter = RecursiveCharacterTextSplitter(
           chunk_size=600,
           chunk_overlap=100
       )

   def extract_and_tag_tables(self, file_path: str, base_meta: Dict[str, Any]) -> List[Dict[str, Any]]:
       """
       Parses PDF tables, isolates automotive keys, computes statistical averages,
       and generates highly detailed metadata tags for exact structural matching.
       """
       table_chunks = []
       
       with pdfplumber.open(file_path) as pdf:
           for page_idx, page in enumerate(pdf.pages):
               tables = page.extract_tables()
               if not tables:
                   continue
                   
               for t_idx, table in enumerate(tables):
                   if not table or len(table) < 2:
                       continue
                   
                   # Process rows and normalize layout headers
                   headers = [str(c).strip() if c else f"col_{i}" for i, c in enumerate(table[0])]
                   rows_data = []
                   
                   for row in table[1:]:
                       row_dict = {}
                       for i, cell in enumerate(row):
                           val = str(cell).strip() if cell else ""
                           header_name = headers[i] if i < len(headers) else f"col_{i}"
                           row_dict[header_name] = val
                       rows_data.append(row_dict)
                   
                   # Generate semantic summary block for vector space search
                   table_summary = f"Structured Data Table on Page {page_idx + 1}:\n"
                   table_summary += json.dumps(rows_data, indent=2)
                   
                   # Run target evaluations for specific critical brake rows
                   for row in rows_data:
                       param_name = row.get("P201 BRAKE TEMPERATURE MAPPING") or row.get("Parameter") or row.get("Description") or ""
                       param_str = str(param_name)
                       
                       if "Front pad peak" in param_str or "FRONT" in param_str:
                           try:
                               cdt_val = float(row.get("CDT", 0))
                               ghd_val = float(row.get("GHD", 0))
                               hsd_val = float(row.get("HSD", 0))
                               
                               cross_cycle_avg = float(np.mean([cdt_val, ghd_val, hsd_val]))
                               
                               specific_meta = base_meta.copy()
                               specific_meta.update({
                                   "page": page_idx + 1,
                                   "chunk_type": "table",
                                   "component": "front_brake",
                                   "metric": "temperature",
                                   "cross_cycle_avg_temp": round(cross_cycle_avg, 2)
                               })
                               
                               table_chunks.append({
                                   "text": f"Component Focus: Front Brake Pad Performance metrics across cycles.\n{table_summary}",
                                   "metadata": specific_meta
                               })
                               continue
                           except ValueError:
                               pass
                       
                       if "Rear Liner peak" in param_str or "REAR" in param_str:
                           try:
                               cdt_val = float(row.get("CDT", 0))
                               ghd_val = float(row.get("GHD", 0))
                               hsd_val = float(row.get("HSD", 0))
                               cross_cycle_avg = float(np.mean([cdt_val, ghd_val, hsd_val]))
                               
                               specific_meta = base_meta.copy()
                               specific_meta.update({
                                   "page": page_idx + 1,
                                   "chunk_type": "table",
                                   "component": "rear_brake",
                                   "metric": "temperature",
                                   "cross_cycle_avg_temp": round(cross_cycle_avg, 2)
                               })
                               
                               table_chunks.append({
                                   "text": f"Component Focus: Rear Brake Liner Performance metrics across cycles.\n{table_summary}",
                                   "metadata": specific_meta
                               })
                               continue
                           except ValueError:
                               pass

                   # Default fallback metadata tag
                   generic_meta = base_meta.copy()
                   generic_meta.update({
                       "page": page_idx + 1,
                       "chunk_type": "table",
                       "component": "general_system",
                       "metric": "specification"
                   })
                   table_chunks.append({"text": table_summary, "metadata": generic_meta})
                   
       return table_chunks

   def extract_narrative_text(self, file_path: str, base_meta: Dict[str, Any]) -> List[Dict[str, Any]]:
       """
       Extracts narrative paragraphs using explicit PyMuPDF instance calls.
       """
       text_chunks = []
       
       # Standard object call with try...finally removes the open context stub type error
       doc = fitz.open(file_path)
       try:
           for page_num in range(len(doc)):
               page = doc[page_num]
               page_text = cast(str, page.get_text("text")).strip()

               if len(page_text) < 40:
                   continue
                   
               splits = self.text_splitter.split_text(page_text)
               
               for split in splits:
                   chunk_meta = base_meta.copy()
                   chunk_meta.update({
                       "page": page_num + 1,
                       "chunk_type": "narrative",
                       "component": "general_system",
                       "metric": "narrative_context"
                   })
                   text_chunks.append({"text": split, "metadata": chunk_meta})
       finally:
           doc.close()
                   
       return text_chunks

   def pipeline_to_vector_db(self, file_path: str, document_metadata: Dict[str, Any]) -> None:
       """
       Executes parsing logic and batch uploads vectors directly into ChromaDB.
       """
       filename = os.path.basename(file_path)
       print(f"🚀 Ingesting pipeline context for: {filename}...")
       
       table_chunks = self.extract_and_tag_tables(file_path, document_metadata)
       narrative_chunks = self.extract_narrative_text(file_path, document_metadata)
       
       all_chunks = table_chunks + narrative_chunks
       print(f"📊 Generated {len(all_chunks)} unique vector payload elements.")
       
       documents = []
       metadatas = []
       ids = []
       
       for idx, chunk in enumerate(all_chunks):
           documents.append(chunk["text"])
           metadatas.append(chunk["metadata"])
           ids.append(f"{document_metadata['doc_id']}_p{chunk['metadata']['page']}_idx_{idx}")
           
       if documents:
           self.collection.add(
               documents=documents,
               metadatas=metadatas,
               ids=ids
           )
           print("✅ Success! Vector index populated inside collection storage database.\n")
       else:
           print("⚠️ Ingestion halted: No viable target structures detected.\n")

   def execute_hybrid_meta_query(self, user_query: str, filters: Optional[Dict[str, Any]] = None) -> Any:
       """
       Week 4 Query Router implementation. Handles explicit filter structures with type overrides.
       """
       print(f"🔍 Routing Query: '{user_query}' | Filter Strategy: {filters}")
       
       if filters:
           # type: ignore silences strict dict type validation expectations from ChromaDB's where module
           results = self.collection.query(query_texts=[user_query], n_results=3, where=filters)  # type: ignore
       else:
           results = self.collection.query(query_texts=[user_query], n_results=3)
           
       return results

